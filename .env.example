# Discord bot token (from https://discord.com/developers/applications -> Bot -> Token)
DISCORD_TOKEN=your-bot-token-here

# Application (client) ID, found on the application's "General Information" page
CLIENT_ID=your-application-id-here

# Optional: register slash commands instantly to a single test server.
# Leave blank to register commands globally (can take up to ~1 hour to appear).
GUILD_ID=

# Default IANA timezone used when a user omits one on /event create
# Examples: America/New_York, America/Los_Angeles, Europe/London, Australia/Sydney
DEFAULT_TIMEZONE=America/New_York

# How many minutes before an event starts to ping signed-up members. 0 disables reminders.
REMINDER_MINUTES=15

# Path to the SQLite database file
DATABASE_PATH=data/ffxi-raid-helper.db
