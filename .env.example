# Discord bot token (from https://discord.com/developers/applications -> Bot -> Token)
DISCORD_TOKEN=your-bot-token-here

# Application (client) ID, found on the application's "General Information" page
CLIENT_ID=your-application-id-here

# Optional: register slash commands instantly to a single test server.
# Leave blank to register commands globally (can take up to ~1 hour to appear).
GUILD_ID=

# Default IANA timezone used when a user omits one on /event create
# Examples: America/New_York, America/Los_Angeles, Europe/London, Australia/Sydney
DEFAULT_TIMEZONE=America/New_York

# How many minutes before an event starts to ping signed-up members. 0 disables reminders.
REMINDER_MINUTES=15

# Optional: default banner image shown on every event when none is provided.
# Override per event with the `image:` option on /event create. Leave blank for none.
DEFAULT_IMAGE_URL=

# Path to the SQLite database file
DATABASE_PATH=data/ffxi-jarvis.db

# ---- Linkshell <-> Discord bridge ----
# The Discord channel that mirrors your in-game linkshell (LS1). Right-click the
# channel in Discord (Developer Mode on) -> Copy Channel ID. Game->Discord needs
# the lsbridge Ashita addon running on THIS PC; Discord->game is served to the
# discordfeed addon via the relay below.
BRIDGE_CHANNEL_ID=
# Optional second linkshell channel (LS2). Leave blank if you only bridge one.
BRIDGE_CHANNEL_ID_2=

# ---- In-game chat relay + Cloudflare tunnel ----
RELAY_PORT=3007
# Comma-separated channel IDs to relay into the game (defaults to BRIDGE_CHANNEL_ID).
RELAY_CHANNEL_IDS=
# Auto-start a Cloudflare quick tunnel for a public relay URL (no port forwarding).
ENABLE_TUNNEL=false
# Optional explicit path to cloudflared if not on PATH.
CLOUDFLARED_PATH=
# Channel to announce the live tunnel URL in (defaults to BRIDGE_CHANNEL_ID).
TUNNEL_ANNOUNCE_CHANNEL_ID=
